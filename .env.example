# Copy to .env for local development.

# PostgreSQL connection string.
# Local example: postgres://postgres:postgres@localhost:5432/jefram
# On Render this is provided automatically by the linked database.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/jefram

# Port the API listens on (Render sets PORT automatically).
PORT=3000

# Secret used to sign admin JWT tokens. Use a long random string in production.
JWT_SECRET=change-me-to-a-long-random-string

# Comma-separated list of allowed CORS origins for the frontends.
# Use * to allow all (fine for a public storefront API).
CORS_ORIGIN=*

# Credentials for the admin account created by `npm run seed`.
SEED_ADMIN_PHONE=256700000000
SEED_ADMIN_PASSWORD=admin123
SEED_ADMIN_NAME=Administrator
